# Default for local dev (outside Docker, point to localhost)
# Inside Docker, this is overridden by docker-compose.yml
DATABASE_URL=postgresql://smartbin:smartbin_dev@localhost:5432/smartbin

# ── MQTT broker for ESP32 telemetry ────────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=8883
MQTT_TOPIC=smartbin/+/telemetry
MQTT_CLIENT_ID=smartbin-api
MQTT_QOS=1

# TLS on by default. For a native dev run against the docker broker,
# point MQTT_CA_CERT at ./mosquitto/certs/ca.crt.
MQTT_TLS=true
MQTT_CA_CERT=./mosquitto/certs/ca.crt
MQTT_CLIENT_CERT=
MQTT_CLIENT_KEY=
MQTT_TLS_INSECURE=false

# Reconnect backoff (paho retries forever)
MQTT_RECONNECT_MIN=1
MQTT_RECONNECT_MAX=60

# Optional host-port override for the mosquitto TLS listener
MQTT_TLS_HOST_PORT=8883

# MQTT_USERNAME / MQTT_PASSWORD are written to .env.secrets by
# scripts/bootstrap.sh — DO NOT commit those.

# ── Production only (docker-compose.prod.yml) ──────────────────
# Public domain — Caddy obtains a Let's Encrypt cert automatically.
DOMAIN=smartbin.example.com

# TimescaleDB password. Rotate per deployment; keep out of git.
POSTGRES_PASSWORD=change-me-in-prod

# Optional: pin a specific backend image tag instead of :latest.
# IMAGE_TAG=<git-sha>
